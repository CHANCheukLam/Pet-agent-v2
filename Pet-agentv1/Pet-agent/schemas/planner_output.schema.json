{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "planner_output.schema.json",
  "title": "PlannerStructuredOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "route_plan_options"
  ],
  "properties": {
    "route_plan_options": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "option_id",
          "option_summary",
          "daily_total_play_hours",
          "route_nodes",
          "route_legs",
          "estimated_total_cost",
          "route_reasoning",
          "constraint_notes"
        ],
        "properties": {
          "option_id": {
            "type": "string",
            "minLength": 1
          },
          "option_summary": {
            "type": "string",
            "minLength": 1
          },
          "daily_total_play_hours": {
            "type": "number",
            "minimum": 0
          },
          "route_nodes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "day_index",
                "scenic_order",
                "scenic_name",
                "planned_stay_duration_minutes"
              ],
              "properties": {
                "day_index": {
                  "type": "integer",
                  "minimum": 1
                },
                "scenic_order": {
                  "type": "integer",
                  "minimum": 1
                },
                "scenic_name": {
                  "type": "string",
                  "minLength": 1
                },
                "planned_stay_duration_minutes": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          },
          "route_legs": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "from_node",
                "to_node",
                "transport_mode",
                "commute_duration_minutes"
              ],
              "properties": {
                "from_node": {
                  "type": "string",
                  "minLength": 1
                },
                "to_node": {
                  "type": "string",
                  "minLength": 1
                },
                "transport_mode": {
                  "type": "string",
                  "enum": [
                    "walk",
                    "taxi",
                    "metro",
                    "bus",
                    "car",
                    "ride_hailing",
                    "unknown",
                    "public_transport",
                    "shared_bike"
                  ]
                },
                "commute_duration_minutes": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          },
          "estimated_total_cost": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          },
          "route_reasoning": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "constraint_notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "reasoning_summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "constraint_satisfaction_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}