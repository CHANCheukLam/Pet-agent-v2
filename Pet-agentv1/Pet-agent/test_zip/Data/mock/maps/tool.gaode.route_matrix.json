{
  "name": "gaode.route_matrix",
  "description": "Gaode many-to-many route matrix for time-space planning and re-planning.",
  "input_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["origins", "destinations", "travel_mode", "need_live_traffic", "pet_constraints"],
    "properties": {
      "origins": {
        "type": "array",
        "minItems": 1,
        "maxItems": 25,
        "items": { "type": "string", "description": "lng,lat" }
      },
      "destinations": {
        "type": "array",
        "minItems": 1,
        "maxItems": 25,
        "items": { "type": "string", "description": "lng,lat" }
      },
      "travel_mode": { "type": "string", "enum": ["driving", "walking", "bicycling", "transit"] },
      "city": { "type": "string" },
      "cityd": { "type": "string" },
      "depart_at": { "type": "string", "format": "date-time" },
      "need_live_traffic": { "type": "boolean", "default": true },
      "alternatives": { "type": "integer", "minimum": 1, "maximum": 3, "default": 1 },
      "pet_constraints": {
        "type": "object",
        "additionalProperties": true,
        "minProperties": 1
      },
      "route_preference": {
        "type": "string",
        "enum": ["fastest", "least_transfer", "least_walk", "avoid_toll", "pet_friendly"],
        "default": "fastest"
      }
    },
    "allOf": [
      {
        "if": {
          "properties": { "travel_mode": { "const": "transit" } },
          "required": ["travel_mode"]
        },
        "then": {
          "required": ["city", "cityd"]
        }
      }
    ]
  },
  "output_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["ok", "request_id", "data", "error"],
    "properties": {
      "ok": { "type": "boolean" },
      "request_id": { "type": "string" },
      "data": {
        "type": ["object", "null"],
        "additionalProperties": false,
        "required": ["source", "travel_mode", "pairs", "updated_at"],
        "properties": {
          "source": { "type": "string", "const": "gaode" },
          "travel_mode": { "type": "string", "enum": ["driving", "walking", "bicycling", "transit"] },
          "pairs": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["origin", "destination", "distance_m", "duration_s"],
              "properties": {
                "origin": { "type": "string" },
                "destination": { "type": "string" },
                "distance_m": { "type": "integer", "minimum": 0 },
                "duration_s": { "type": "integer", "minimum": 0 },
                "walking_distance_m": { "type": "integer", "minimum": 0 },
                "transfers": { "type": "integer", "minimum": 0 },
                "cost_cny": { "type": "number", "minimum": 0 },
                "tolls_cny": { "type": "number", "minimum": 0 },
                "traffic_status": { "type": "string", "enum": ["smooth", "slow", "jam", "severe_jam", "unknown"] }
              }
            }
          },
          "updated_at": { "type": "string", "format": "date-time" },
          "upstream_status": { "type": "string" },
          "upstream_code": { "type": "string" },
          "upstream_message": { "type": "string" }
        }
      },
      "error": {
        "type": ["object", "null"],
        "additionalProperties": false,
        "required": ["code", "message", "retryable"],
        "properties": {
          "code": { "type": "string", "enum": ["VALIDATION_ERROR", "AUTH_FAILED", "RATE_LIMITED", "TIMEOUT", "UPSTREAM_ERROR", "UPSTREAM_EMPTY"] },
          "message": { "type": "string" },
          "retryable": { "type": "boolean" },
          "upstream_status": { "type": "string" },
          "upstream_code": { "type": "string" }
        }
      }
    },
    "oneOf": [
      { "properties": { "ok": { "const": true }, "data": { "type": "object" }, "error": { "type": "null" } } },
      { "properties": { "ok": { "const": false }, "data": { "type": "null" }, "error": { "type": "object" } } }
    ]
  },
  "meta": {
    "provider": "gaode",
    "version": "1.1.0",
    "timeout_ms": 3500,
    "retries": 1,
    "cache_ttl_seconds": 60
  }
}
