{
  "name": "qweather.minutely",
  "description": "QWeather minute-level precipitation in next 2 hours.",
  "input_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["location"],
    "properties": {
      "location": { "type": "string", "description": "location id or lng,lat" },
      "lang": { "type": "string", "default": "zh" }
    }
  },
  "output_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["ok", "request_id", "data", "error"],
    "properties": {
      "ok": { "type": "boolean" },
      "request_id": { "type": "string" },
      "data": {
        "type": ["object", "null"],
        "additionalProperties": false,
        "required": ["source", "will_rain_2h", "minutes", "updated_at"],
        "properties": {
          "source": { "type": "string", "const": "qweather" },
          "will_rain_2h": { "type": "boolean" },
          "summary": { "type": "string" },
          "minutes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["fx_time", "precip_mm"],
              "properties": {
                "fx_time": { "type": "string", "format": "date-time" },
                "precip_mm": { "type": "number", "minimum": 0 }
              }
            }
          },
          "updated_at": { "type": "string", "format": "date-time" },
          "upstream_status": { "type": "string" },
          "upstream_code": { "type": "string" },
          "upstream_message": { "type": "string" }
        }
      },
      "error": {
        "type": ["object", "null"],
        "additionalProperties": false,
        "required": ["code", "message", "retryable"],
        "properties": {
          "code": { "type": "string", "enum": ["VALIDATION_ERROR", "AUTH_FAILED", "RATE_LIMITED", "TIMEOUT", "UPSTREAM_ERROR", "UPSTREAM_EMPTY"] },
          "message": { "type": "string" },
          "retryable": { "type": "boolean" },
          "upstream_status": { "type": "string" },
          "upstream_code": { "type": "string" }
        }
      }
    },
    "oneOf": [
      { "properties": { "ok": { "const": true }, "data": { "type": "object" }, "error": { "type": "null" } } },
      { "properties": { "ok": { "const": false }, "data": { "type": "null" }, "error": { "type": "object" } } }
    ]
  },
  "meta": {
    "provider": "qweather",
    "version": "1.0.0",
    "timeout_ms": 2500,
    "retries": 1,
    "cache_ttl_seconds": 600
  }
}
