{
  "name": "gaode.route_transit",
  "description": "Gaode public transit route planning (metro + bus transfer plans).",
  "input_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["origin", "destination", "city"],
    "properties": {
      "origin": { "type": "string", "description": "lng,lat" },
      "destination": { "type": "string", "description": "lng,lat" },
      "city": { "type": "string", "minLength": 1 },
      "cityd": { "type": "string", "minLength": 1 },
      "strategy": { "type": "integer", "minimum": 0, "maximum": 5, "default": 0 },
      "nightflag": { "type": "boolean", "default": false }
    }
  },
  "output_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["ok", "request_id", "data", "error"],
    "properties": {
      "ok": { "type": "boolean" },
      "request_id": { "type": "string" },
      "data": {
        "type": ["object", "null"],
        "additionalProperties": false,
        "required": ["source", "plans", "updated_at"],
        "properties": {
          "source": { "type": "string", "const": "gaode" },
          "plans": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["duration_s", "walking_distance_m", "transfers"],
              "properties": {
                "duration_s": { "type": "integer", "minimum": 0 },
                "walking_distance_m": { "type": "integer", "minimum": 0 },
                "transfers": { "type": "integer", "minimum": 0 },
                "cost_cny": { "type": "number", "minimum": 0 },
                "segments": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "updated_at": { "type": "string", "format": "date-time" },
          "upstream_status": { "type": "string" },
          "upstream_code": { "type": "string" },
          "upstream_message": { "type": "string" }
        }
      },
      "error": {
        "type": ["object", "null"],
        "additionalProperties": false,
        "required": ["code", "message", "retryable"],
        "properties": {
          "code": { "type": "string", "enum": ["VALIDATION_ERROR", "AUTH_FAILED", "RATE_LIMITED", "TIMEOUT", "UPSTREAM_ERROR", "UPSTREAM_EMPTY"] },
          "message": { "type": "string" },
          "retryable": { "type": "boolean" },
          "upstream_status": { "type": "string" },
          "upstream_code": { "type": "string" }
        }
      }
    },
    "oneOf": [
      { "properties": { "ok": { "const": true }, "data": { "type": "object" }, "error": { "type": "null" } } },
      { "properties": { "ok": { "const": false }, "data": { "type": "null" }, "error": { "type": "object" } } }
    ]
  },
  "meta": {
    "provider": "gaode",
    "version": "1.0.0",
    "timeout_ms": 3500,
    "retries": 1,
    "cache_ttl_seconds": 120
  }
}
