{
  "name": "gaode.traffic_live",
  "description": "Gaode live traffic snapshot for congestion-aware planning and re-planning.",
  "input_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["location", "radius_m"],
    "properties": {
      "location": { "type": "string", "description": "lng,lat" },
      "radius_m": { "type": "integer", "minimum": 100, "maximum": 5000 },
      "granularity": { "type": "string", "enum": ["area", "route"], "default": "area" },
      "route_polyline": { "type": "string" },
      "current_time": { "type": "string", "format": "date-time" }
    }
  },
  "output_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["ok", "request_id", "data", "error"],
    "properties": {
      "ok": { "type": "boolean" },
      "request_id": { "type": "string" },
      "data": {
        "type": ["object", "null"],
        "additionalProperties": false,
        "required": ["source", "congestion_level", "updated_at"],
        "properties": {
          "source": { "type": "string", "const": "gaode" },
          "congestion_level": { "type": "string", "enum": ["low", "medium", "high", "severe"] },
          "affected": { "type": "boolean" },
          "recommend_replan": { "type": "boolean" },
          "replan_reason": { "type": "string" },
          "avg_speed_kmh": { "type": "number", "minimum": 0 },
          "affected_roads": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "congestion_level"],
              "properties": {
                "name": { "type": "string" },
                "congestion_level": { "type": "string", "enum": ["low", "medium", "high", "severe"] },
                "speed_kmh": { "type": "number", "minimum": 0 },
                "delay_s": { "type": "integer", "minimum": 0 }
              }
            }
          },
          "updated_at": { "type": "string", "format": "date-time" },
          "upstream_status": { "type": "string" },
          "upstream_code": { "type": "string" },
          "upstream_message": { "type": "string" }
        }
      },
      "error": {
        "type": ["object", "null"],
        "additionalProperties": false,
        "required": ["code", "message", "retryable"],
        "properties": {
          "code": { "type": "string", "enum": ["VALIDATION_ERROR", "AUTH_FAILED", "RATE_LIMITED", "TIMEOUT", "UPSTREAM_ERROR", "UPSTREAM_EMPTY"] },
          "message": { "type": "string" },
          "retryable": { "type": "boolean" },
          "upstream_status": { "type": "string" },
          "upstream_code": { "type": "string" }
        }
      }
    },
    "oneOf": [
      { "properties": { "ok": { "const": true }, "data": { "type": "object" }, "error": { "type": "null" } } },
      { "properties": { "ok": { "const": false }, "data": { "type": "null" }, "error": { "type": "object" } } }
    ]
  },
  "meta": {
    "provider": "gaode",
    "version": "1.1.0",
    "timeout_ms": 3000,
    "retries": 1,
    "cache_ttl_seconds": 30
  }
}
