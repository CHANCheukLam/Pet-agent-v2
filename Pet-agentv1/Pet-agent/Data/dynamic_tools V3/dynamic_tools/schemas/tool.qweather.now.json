{
  "name": "qweather.now",
  "description": "QWeather real-time weather conditions. 'location' must be lng,lat or Location ID (not city name).",
  "input_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["location"],
    "properties": {
      "location": { "type": "string", "description": "location id or lng,lat" },
      "lang": { "type": "string", "default": "zh" },
      "unit": { "type": "string", "enum": ["m", "i"], "default": "m" }
    }
  },
  "output_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["ok", "request_id", "data", "error"],
    "properties": {
      "ok": { "type": "boolean" },
      "request_id": { "type": "string" },
      "data": {
        "type": ["object", "null"],
        "additionalProperties": false,
        "required": ["source", "now", "updated_at"],
        "properties": {
          "source": { "type": "string", "const": "qweather" },
          "now": {
            "type": "object",
            "additionalProperties": false,
            "required": ["obs_time", "temp_c", "feels_like_c", "text"],
            "properties": {
              "obs_time": { "type": "string", "format": "date-time" },
              "temp_c": { "type": "number" },
              "feels_like_c": { "type": "number" },
              "text": { "type": "string" },
              "humidity_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
              "wind_dir": { "type": "string" },
              "wind_scale": { "type": "string" },
              "precip_mm": { "type": "number", "minimum": 0 }
            }
          },
          "pet_comfort": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "level": { "type": "string", "enum": ["comfortable", "caution", "risky"] },
              "reason": { "type": "string" }
            }
          },
          "updated_at": { "type": "string", "format": "date-time" },
          "upstream_status": { "type": "string" },
          "upstream_code": { "type": "string" },
          "upstream_message": { "type": "string" }
        }
      },
      "error": {
        "type": ["object", "null"],
        "additionalProperties": false,
        "required": ["code", "message", "retryable"],
        "properties": {
          "code": { "type": "string", "enum": ["VALIDATION_ERROR", "AUTH_FAILED", "RATE_LIMITED", "TIMEOUT", "UPSTREAM_ERROR", "UPSTREAM_EMPTY"] },
          "message": { "type": "string" },
          "retryable": { "type": "boolean" },
          "upstream_status": { "type": "string" },
          "upstream_code": { "type": "string" }
        }
      }
    },
    "oneOf": [
      { "properties": { "ok": { "const": true }, "data": { "type": "object" }, "error": { "type": "null" } } },
      { "properties": { "ok": { "const": false }, "data": { "type": "null" }, "error": { "type": "object" } } }
    ]
  },
  "meta": {
    "provider": "qweather",
    "version": "1.0.0",
    "timeout_ms": 2500,
    "retries": 1,
    "cache_ttl_seconds": 300,
    "api_key": "6ce2a6904f924dd7affe0a697c83ca7a",
    "api_host": "abc1234xyz.def.qweatherapi.com"
  }
}
