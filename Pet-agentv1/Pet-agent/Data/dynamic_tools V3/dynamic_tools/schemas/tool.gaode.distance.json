{
  "name": "gaode.distance",
  "description": "Gaode distance measurement between origin(s) and destination.",
  "input_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["origins", "destination"],
    "properties": {
      "origins": {
        "type": "array",
        "minItems": 1,
        "maxItems": 20,
        "items": { "type": "string", "description": "lng,lat" }
      },
      "destination": { "type": "string", "description": "lng,lat" },
      "type": { "type": "integer", "enum": [0, 1], "default": 1, "description": "0=straight line, 1=driving" }
    }
  },
  "output_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["ok", "request_id", "data", "error"],
    "properties": {
      "ok": { "type": "boolean" },
      "request_id": { "type": "string" },
      "data": {
        "type": ["object", "null"],
        "additionalProperties": false,
        "required": ["source", "results", "updated_at"],
        "properties": {
          "source": { "type": "string", "const": "gaode" },
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["origin", "destination", "distance_m"],
              "properties": {
                "origin": { "type": "string" },
                "destination": { "type": "string" },
                "distance_m": { "type": "integer", "minimum": 0 },
                "duration_s": { "type": "integer", "minimum": 0 }
              }
            }
          },
          "updated_at": { "type": "string", "format": "date-time" },
          "upstream_status": { "type": "string" },
          "upstream_code": { "type": "string" },
          "upstream_message": { "type": "string" }
        }
      },
      "error": {
        "type": ["object", "null"],
        "additionalProperties": false,
        "required": ["code", "message", "retryable"],
        "properties": {
          "code": { "type": "string", "enum": ["VALIDATION_ERROR", "AUTH_FAILED", "RATE_LIMITED", "TIMEOUT", "UPSTREAM_ERROR", "UPSTREAM_EMPTY"] },
          "message": { "type": "string" },
          "retryable": { "type": "boolean" },
          "upstream_status": { "type": "string" },
          "upstream_code": { "type": "string" }
        }
      }
    },
    "oneOf": [
      { "properties": { "ok": { "const": true }, "data": { "type": "object" }, "error": { "type": "null" } } },
      { "properties": { "ok": { "const": false }, "data": { "type": "null" }, "error": { "type": "object" } } }
    ]
  },
  "meta": {
    "provider": "gaode",
    "version": "1.0.0",
    "timeout_ms": 2500,
    "retries": 1,
    "cache_ttl_seconds": 600
  }
}
