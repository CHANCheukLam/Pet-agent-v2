{
  "name": "gaode.route_bicycling",
  "description": "Gaode bicycling route planning for bike-share and leisure riding.",
  "input_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["origin", "destination"],
    "properties": {
      "origin": { "type": "string", "description": "lng,lat" },
      "destination": { "type": "string", "description": "lng,lat" },
      "show_fields": { "type": "array", "items": { "type": "string", "enum": ["steps", "polyline"] } }
    }
  },
  "output_schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["ok", "request_id", "data", "error"],
    "properties": {
      "ok": { "type": "boolean" },
      "request_id": { "type": "string" },
      "data": {
        "type": ["object", "null"],
        "additionalProperties": false,
        "required": ["source", "routes", "updated_at"],
        "properties": {
          "source": { "type": "string", "const": "gaode" },
          "routes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["distance_m", "duration_s"],
              "properties": {
                "distance_m": { "type": "integer", "minimum": 0 },
                "duration_s": { "type": "integer", "minimum": 0 },
                "polyline": { "type": "string" },
                "steps": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "updated_at": { "type": "string", "format": "date-time" },
          "upstream_status": { "type": "string" },
          "upstream_code": { "type": "string" },
          "upstream_message": { "type": "string" }
        }
      },
      "error": {
        "type": ["object", "null"],
        "additionalProperties": false,
        "required": ["code", "message", "retryable"],
        "properties": {
          "code": { "type": "string", "enum": ["VALIDATION_ERROR", "AUTH_FAILED", "RATE_LIMITED", "TIMEOUT", "UPSTREAM_ERROR", "UPSTREAM_EMPTY"] },
          "message": { "type": "string" },
          "retryable": { "type": "boolean" },
          "upstream_status": { "type": "string" },
          "upstream_code": { "type": "string" }
        }
      }
    },
    "oneOf": [
      { "properties": { "ok": { "const": true }, "data": { "type": "object" }, "error": { "type": "null" } } },
      { "properties": { "ok": { "const": false }, "data": { "type": "null" }, "error": { "type": "object" } } }
    ]
  },
  "meta": {
    "provider": "gaode",
    "version": "1.0.0",
    "timeout_ms": 3000,
    "retries": 1,
    "cache_ttl_seconds": 60
  }
}
